# ----- vLLM / LLM -----
# OpenAI-compatible endpoint exposed by vLLM (local or Modal).
JARVIS_LLM_BASE_URL=http://localhost:8000/v1
JARVIS_LLM_API_KEY=EMPTY
JARVIS_LLM_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
JARVIS_LLM_TEMPERATURE=0.2
JARVIS_LLM_MAX_TOKENS=1024
JARVIS_LLM_TIMEOUT=120

# ----- Speech-to-Text (faster-whisper) -----
# Models: tiny.en, base.en, small.en, medium.en, large-v3
JARVIS_STT_MODEL=base.en
JARVIS_STT_DEVICE=auto          # auto | cpu | cuda
JARVIS_STT_COMPUTE_TYPE=int8    # int8 | int8_float16 | float16 | float32
JARVIS_STT_LANGUAGE=en

# ----- Text-to-Speech (Piper) -----
# Download a voice from https://github.com/rhasspy/piper/blob/master/VOICES.md
# and point JARVIS_TTS_VOICE at the .onnx file (the .onnx.json must sit beside it).
JARVIS_TTS_VOICE=./voices/en_GB-alan-medium.onnx
JARVIS_TTS_SPEED=1.0

# ----- Audio I/O -----
JARVIS_INPUT_DEVICE=              # blank = default input
JARVIS_OUTPUT_DEVICE=             # blank = default output
JARVIS_SAMPLE_RATE=16000
JARVIS_VAD_AGGRESSIVENESS=2       # 0 (loose) .. 3 (strict)
JARVIS_SILENCE_MS=700             # end-of-utterance silence threshold
JARVIS_MIN_UTTERANCE_MS=300
JARVIS_MAX_UTTERANCE_MS=30000

# ----- Workspace -----
# The directory Jarvis may read/edit/run commands in.
JARVIS_WORKSPACE=.
JARVIS_ALLOW_WRITES=false
JARVIS_ALLOW_SHELL=false

# ----- Telegram bridge -----
# Create a bot via @BotFather and paste the token below.
JARVIS_TELEGRAM_TOKEN=
# Comma-separated numeric chat IDs authorised to talk to Jarvis.
JARVIS_TELEGRAM_ALLOWED_CHATS=
# Chat ID used for push notifications / warnings.
JARVIS_TELEGRAM_NOTIFY_CHAT=

# ----- Wake word -----
# JARVIS_WAKE_ENABLED=true uses openWakeWord (install: pip install openwakeword).
# Fall back to text-only matching by setting JARVIS_WAKE_ENABLED=false and
# JARVIS_REQUIRE_WAKE_WORD=true.
JARVIS_WAKE_ENABLED=true
JARVIS_WAKE_WORD=hey jarvis
JARVIS_WAKE_MODEL=hey_jarvis_v0.1
JARVIS_WAKE_THRESHOLD=0.5
JARVIS_REQUIRE_WAKE_WORD=false

# ----- Streaming voice output -----
# When true, sentences are synthesised as soon as the LLM emits them.
JARVIS_STREAM_VOICE=true

# ----- Watch mode -----
# Comma-separated paths. Command is optional; when set it runs on each change
# and its exit status is pushed to the notify chat.
JARVIS_WATCH_PATHS=.
JARVIS_WATCH_COMMAND=
JARVIS_WATCH_DEBOUNCE_MS=400

# ----- Long-term memory -----
# Episodic log of every turn + distilled user profile re-injected into the
# system prompt. The profile is refreshed in the background after every
# JARVIS_MEMORY_REFRESH_EVERY user messages. Set JARVIS_MEMORY_ENABLED=false
# to opt out entirely (the DB file is left untouched).
JARVIS_MEMORY_ENABLED=true
JARVIS_MEMORY_DB=./.jarvis/memory.db
JARVIS_MEMORY_REFRESH_EVERY=10
JARVIS_MEMORY_CONTEXT_TURNS=60
